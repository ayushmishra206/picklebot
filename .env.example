# Path to persisted session/player state
PICKLEPILOT_DATA_FILE=./data/picklepilot.json

# WhatsApp group JID to listen on (format: 1234567890-1234567890@g.us)
# Leave unset to respond in ALL groups the linked number is in.
PICKLEPILOT_GROUP_ID=

# Directory where Baileys stores the WhatsApp auth session (multi-file keys)
PICKLEPILOT_AUTH_DIR=./auth
